function cabecalho_tardis(){
    VERSION=$(gum style --foreground 245 --italic "v1.3.0")
    TARDIS=$(gum style --bold "T.A.R.D.I.S")
    
    gum style \
    --foreground 39 --border double --border-foreground 39 \
    --padding "1 2" --margin "1" --align center --width 60 \
    "$TARDIS" "" "Transformador Automático de Rotinas e" "Diversões Inúteis do Sistema" "" "$VERSION"
}

function backup() {
    while true; do
	clear
        cabecalho_tardis

	menu_backup=$(gum choose --cursor.foreground 39 --selected.foreground 39 \
			   "📦 Total" \
			   "📂 Total separado" \
			   "⚡ Parcial" \
			   "☀️  Domingo" \
			   "↩️  Voltar")
	
	case $menu_backup in
	    *"Total"*) command backup -t ;;
	    *"Total separada"*) command backup -ts ;;
	    *"Parcial"*) command backup -p ;;
	    *"Domingo"*) command backup -d ;;
	    *"Voltar"*) return 0 ;;
	esac
    done
}    

function criar_script() {
    while true; do
	clear
	cabecalho_tardis

	gum style --foreground 39 --bold "📜 Criar Novo Script"
	dir=$(gum input --placeholder "Em qual diretório deseja criar o script? (ou 0 para voltar)")
	
	if [[ "$dir" == "0" || -z "$dir" ]]; then
	    break
	fi

	script_name=$(gum input --placeholder "Qual deve ser o nome do script? (ou 0 para voltar)")

	if [[ "$script_name" == "0" || -z "$script_name" ]]; then
	    break
	fi

	eval dir_expandido="$dir"
	command cs "$dir_expandido" "$script_name"

	gum style --foreground 82 "✅ Script '$script_name' criado com sucesso em $dir_expandido!"

	if ! gum confirm --affirmative "Sim" --negative "Não" "Deseja criar outro script?"; then
            break
        fi
    done
}

function imperial_date() {
    while true; do
	clear
	cabecalho_tardis
	
	data_res=$(command imperial_date)

	gum style \
        --foreground 220 --border double --border-foreground 220 \
        --padding "1 2" --margin "1" --align center --width 50 \
        "👑 DATA IMPERIAL" "" "$data_res"

	echo ''
	
	if gum confirm --affirmative "Atualizar" --negative "Voltar" "O que deseja fazer?"; then
            continue
	else
            break
	fi
    done
}

function stardate() {
    while true; do
	clear
	cabecalho_tardis
	
	data_res=$(command stardate)

	gum style \
        --foreground 99 --border double --border-foreground 99 \
        --padding "1 2" --margin "1" --align center --width 50 \
        "👑 DATA ESTELAR" "" "$data_res"

	echo ''
	
	if gum confirm --affirmative "Atualizar" --negative "Voltar" "O que deseja fazer?"; then
            continue
	else
            break
	fi
    done
}

function versao() {
    clear
    gum style --foreground 212 --bold "🏷️ MANUAL DE VERSIONAMENTO (SemVer)"
    command versao | gum pager --show-line-numbers --foreground 255
}

while true; do
    clear
    cabecalho_tardis

    menu_principal=$(gum choose --header "Selecione" --cursor.foreground 39 --selected.foreground 39 \
    "📦 Backup" "📜 Criar script" "👑 Data Imperial" "✨ Data Estelar" \
    "🏷️  Versionamento" "🚪 Sair")
    
    case "$menu_principal" in
	*"Backup"*) backup ;;
	*"Criar script"*) criar_script ;;
	*"Data Imperial"*) imperial_date ;;
	*"Data Estelar"*) stardate ;;
	*"Versionamento"*) versao ;;
	*"Sair"*) clear ; echo "Bye" ; break ;;
    esac
done

